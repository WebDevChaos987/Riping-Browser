{
  "$schema": "https://schema.tauri.app/config/v2",
  "productName": "Riping",
  "version": "0.1.0",
  "identifier": "com.riping.browser",
  "bundle": {
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all"
  },
  "app": {
    "windows": [
      {
        "title": "Riping Browser",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "build": {
    "frontendDist": "../"
  }
}
 
